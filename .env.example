# TQNN MCP Server — Environment Configuration
# Copy this to .env and fill in your credentials.
# Never commit .env to version control.

# DMM endpoint — use tqnn.local for local Pi5, dmm.toridion.com for production
TQNN_BASE_URL=https://tqnn.local

# API credentials from your TQNN console
TQNN_API_KEY=your_api_key_here
TQNN_API_SECRET=your_api_secret_here

# Dataset to search — e.g. lindisfarne-m1 (leave blank for appliance default)
TQNN_DATASET=demoapp

# TLS: set to 0 for tqnn.local (self-signed cert), leave unset for dmm.toridion.com
NODE_TLS_REJECT_UNAUTHORIZED=0

# MCP server mode: stdio (Claude Code) or sse (claude.ai / remote)
MCP_MODE=stdio

# Port for SSE mode only
MCP_PORT=3100
