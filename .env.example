# ── TQNN DMM Connection ─────────────────────────────────────────────────────
TQNN_BASE_URL=https://tqnn.local
TQNN_API_KEY=your_api_key_here
TQNN_API_SECRET=your_api_secret_here
TQNN_DATASET=lindisfarne-m1

# Set to 0 only for tqnn.local self-signed cert. Remove for public HTTPS.
NODE_TLS_REJECT_UNAUTHORIZED=0

# ── MCP Server Mode ──────────────────────────────────────────────────────────
MCP_MODE=sse
MCP_PORT=3100

# ── OAuth 2.1 (required in SSE mode) ────────────────────────────────────────

# The public HTTPS URL of this server (your ngrok URL — update on each restart
# unless you have a fixed ngrok domain on a paid plan).
TQNN_PUBLIC_URL=https://sprint-umpire-wrongdoer.ngrok-free.dev

# HMAC secret for signing access tokens. Generate once and keep it fixed.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
TQNN_MCP_SECRET=REPLACE_WITH_GENERATED_SECRET_MIN_32_CHARS

# Credentials for the OAuth consent screen (what you log in with in the browser
# when claude.ai redirects you to authorise).
TQNN_OAUTH_USER=admin
TQNN_OAUTH_PASS=REPLACE_WITH_STRONG_PASSWORD

# ── CORS (optional, defaults to *) ──────────────────────────────────────────
# Restrict to claude.ai in production.
# CORS_ORIGIN=https://claude.ai
